# Copy this file to .env.local and fill in your values

# Azure Cosmos DB (Serverless)
# Find these in Azure Portal → your Cosmos DB account → Keys
COSMOS_ENDPOINT=https://YOUR_ACCOUNT.documents.azure.com:443/
COSMOS_KEY=YOUR_PRIMARY_KEY_HERE
COSMOS_DB=visitourvilla

# Resend (transactional email) — https://resend.com
# Create a free account, verify your domain, and paste your API key here
RESEND_API_KEY=re_YOUR_KEY_HERE

# Email address where booking requests and contact messages are delivered
HOST_EMAIL=stay@vistaloopvilla.com
